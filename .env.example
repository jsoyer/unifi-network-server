# UniFi Network Server — Docker Compose environment variables
# Copy to .env and uncomment/adjust values as needed.

# Compose project name (used for container and volume naming)
COMPOSE_PROJECT_NAME=unifi

# Docker image tag to use (default: latest)
# TAG=latest

# Timezone (e.g. Europe/Paris, America/New_York, Asia/Tokyo)
# TZ=UTC

# JVM heap size for the UniFi controller (default: 1024M)
# Increase if managing many devices or experiencing OOM errors.
# JVM_MAX_HEAP_SIZE=1024M
# JVM_INIT_HEAP_SIZE=512M

# Enable optimisations for large deployments (50+ devices)
# Sets G1GC, reduces MongoDB I/O journaling.
# LOTSOFDEVICES=true

# Override the controller IP advertised to devices for adoption.
# Required if running behind NAT or with multiple network interfaces.
# SYSTEM_IP=

# Forward UniFi application logs to Docker stdout (visible via docker logs)
# UNIFI_STDOUT=true

# Custom ports (defaults shown)
# UNIFI_HTTP_PORT=8080
# UNIFI_HTTPS_PORT=8443
# PORTAL_HTTP_PORT=8880
# PORTAL_HTTPS_PORT=8843

# Custom UID/GID for the unifi user inside the container (default: 999)
# UNIFI_UID=999
# UNIFI_GID=999

# Run as root (not recommended — disables security hardening)
# RUNAS_UID0=false

# External MongoDB URIs (set all three to use an external MongoDB instance)
# DB_URI=mongodb://mongo/unifi
# STATDB_URI=mongodb://mongo/unifi_stat
# DB_NAME=unifi

# Enable ECC certificate cipher suites (set to true if using an ECC cert)
# UNIFI_ECC_CERT=false
